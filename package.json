{
  "name": "waitlist",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "commit": "node scripts/commit/parallel-commit.js",
    "commit:dry": "node scripts/commit/parallel-commit.js --dry-run",
    "commit:sh": "bash scripts/commit/parallel-commit.sh",
    "commit:sh:dry": "bash scripts/commit/parallel-commit.sh --dry-run",
    "commit:all": "git add -A && git commit -m \"chore: update project files\"",
    "commit:auto": "bash scripts/commit/parallel-commit.sh --max 3",
    "status": "git status",
    "changes": "git status --porcelain",
    "staged": "git diff --cached --name-only"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.92.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.2.0",
    "lucide-react": "^0.563.0",
    "next": "^16.2.1",
    "postprocessing": "^6.39.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "resend": "^6.8.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
